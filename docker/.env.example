# OpenRAG configuration for SolidMind CAD
# Copy this file to .env and fill in values as needed.

# URL where the MCP server reaches OpenRAG (default for Docker setup)
OPENRAG_URL=http://localhost:8080

# Optional API key for OpenRAG (leave empty if not configured)
OPENRAG_API_KEY=

# Port to expose OpenRAG on the host
OPENRAG_PORT=8080

# LLM provider keys (needed by Langflow for embedding models)
# Uncomment and set the one you use:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
