# OpenRAG configuration for SolidMind CAD
# Copy this file to .env and fill in values as needed.

# URL where the MCP server reaches OpenRAG backend (default for Docker setup)
OPENRAG_URL=http://localhost:8080

# API key for OpenRAG /v1/* endpoints (generate one via the OpenRAG UI or API)
OPENRAG_API_KEY=

# Port to expose OpenRAG backend on the host
OPENRAG_PORT=8080

# Optional: Docling URL for direct document extraction (Mode A)
# If not set, extract uses the OpenRAG backend's upload flow instead.
DOCLING_URL=http://localhost:5001

# OpenSearch admin password (required)
OPENSEARCH_PASSWORD=YourStrongPassword123!

# OpenSearch index name
OPENSEARCH_INDEX_NAME=documents

# Langflow credentials
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=admin

# LLM provider keys (needed by Langflow for embedding models)
# At least one is required for semantic search to work.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_ENDPOINT=http://host.docker.internal:11434
